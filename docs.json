{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Mkplace",
  "colors": {
    "primary": "#0f0f1f",
    "light": "#FFFFFF",
    "dark": "#6366F1"
  },
  "favicon": {
    "light": "/favicon.svg",
    "dark": "/favicon.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Introdução",
        "pages": ["index"]
      },
      {
        "tab": "Integração de Vendedores",
        "groups": [
          {
            "group": "Começando",
            "pages": [
              "sellers/index",
              "sellers/autenticacao"
            ]
          },
          {
            "group": "Configurações",
            "pages": [
              "sellers/configuracoes/index",
              "sellers/configuracoes/cotacao-frete",
              "sellers/configuracoes/webhook-pedidos"
            ]
          },
          {
            "group": "Catálogo",
            "pages": [
              "sellers/produtos-ofertas"
            ]
          },
          {
            "group": "Pedidos",
            "pages": [
              "sellers/pedidos/index",
              "sellers/pedidos/schema"
            ]
          },
          {
            "group": "Encerramento",
            "pages": [
              "sellers/conclusao"
            ]
          },
          {
            "group": "Referência da API",
            "openapi": "api-reference/openapi/plataforma-mkplace.json"
          }
        ]
      },
      {
        "tab": "Integração de Lojas",
        "groups": [
          {
            "group": "Começando",
            "pages": [
              "stores/index",
              "stores/em-breve"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Site Mkplace",
          "href": "https://www.mkplace.com.br/",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/a46a27757e30601e5901df3f7d4a8abaf2d642a3_5dd5fba8c7515d2dc58448400png.png",
    "dark": "/images/a46a27757e30601e5901df3f7d4a8abaf2d642a3_5dd5fba8c7515d2dc58448400png.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Suporte",
        "href": "mailto:suporte@mkplace.com.br"
      }
    ]
  },
  "contextual": {
    "options": [
      "view",
      "mcp",
      "vscode",
      "download-spec",
      "claude",
      "chatgpt"
    ]
  },
  "background": {
    "color": {
      "dark": "#0f0f1f"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "icons": {
    "library": "fontawesome"
  },
  "metadata": {
    "timestamp": false
  },
  "styling": {
    "codeblocks": "dark"
  },
  "interaction": {
    "drilldown": true
  },
  "search": {
    "prompt": "Buscar ..."
  },
  "markdown": {
    "schema": false
  },
  "api": {
    "playground": {
      "proxy": true
    },
    "examples": {
      "defaults": "all"
    },
    "mdx": {
      "auth": {
        "method": "bearer",
        "name": "Authorization"
      },
      "server": [
        "https://api.main.mkplace.com",
        "https://api.main.mkplace.com.br"
      ]
    }
  }
}
