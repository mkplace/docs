{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Mkplace",
  "colors": {
    "primary": "#0f0f1f",
    "light": "#FFFFFF",
    "dark": "#0f0f1f"
  },
  "favicon": {
    "light": "/favicon.svg",
    "dark": "/favicon.svg"
  },
  "navigation": {
    "pages": ["index", "quickstart"],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/a46a27757e30601e5901df3f7d4a8abaf2d642a3_5dd5fba8c7515d2dc58448400png.png",
    "dark": "/images/a46a27757e30601e5901df3f7d4a8abaf2d642a3_5dd5fba8c7515d2dc58448400png.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
    "view",
    "mcp",
    "vscode",
    "download-spec",
    "claude",
    "chatgpt"
   ]
  },
  "background": {
    "color": {
      "dark": "#0f0f1f"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "icons": {
    "library": "fontawesome"
  },
  "metadata": {
    "timestamp": false
  },
  "styling": {
    "codeblocks": "dark"
  },
  "interaction": {
    "drilldown": true
  },
  "search": {
    "prompt": "Buscar ..."
  },
  "markdown": {
    "schema": false
  },
  "api": {
    "playground": {
      "proxy": true
    },
    "examples": {
      "defaults": "all"
    },
    "mdx": {
      "auth": {
        "method": "bearer",
        "name": "Authorization"
      },
      "server": [
        "https://api.main.mkplace.com",
        "https://api.main.mkplace.com.br"
      ]
    }
  }
}
