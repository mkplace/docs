// Walkthrough do objeto Order nos status do ciclo de vida (PRE-ORDER -> DELIVERED, + CANCELED e EXPIRED).
// Arquivo de referência comentado campo a campo. Os comentarios (//) tornam este arquivo um JSONC (não é JSON puro).

// Pedido - PRE-ORDER
{
    "_id": "OrderId-PRE", // Id do Pedido dentro da MkPlace
    "clientId": "customer-services", // origem/cliente da API que criou o pedido
    "storeId": "STORE123ABC", // loja dona do pedido
    "accountId": "acc-0001", // conta (multi-tenant)
    "type": "ORDER", // tipo do pedido: ORDER | LOYALTY | SUBSCRIPTION
    "status": "PRE-ORDER", // status do Pedido
    "paymentStatus": "PRE-ORDER", // status do pagamento do pedido
    "orderRef": "REF-0001", // referência externa do pedido
    "cartId": "cart-uuid-0001", // carrinho que originou o pedido
    "channelSlug": null, // canal de venda
    "verifyToken": "verify-token-uuid", // representação do pedido em forma cifrada
    "stockReservation": true, // houve reserva de estoque
    "isOrderModified": false, // pedido foi modificado apos a criação
    "payments": [], // deprecated — não é mais utilizado
    "promotions": [ // promoções aplicadas ao pedido (vazio/null quando não há)
        {
            "type": "item", // escopo: "cart" (pedido), "item" (SKU) ou "freight" (frete)
            "promotionId": "PromotionId-uuid",
            "promotionName": "10OFF", // nome legível da promoção
            "promotionType": "default", // "default", "bonus", "cashback" ou "points"
            "discountType": "fixed", // "fixed" (R$) ou "percentage" (%)
            "value": 10, // desconto configurado
            "valueApplied": 10, // valor em R$ efetivamente abatido
            "sellerId": "SellerId-uuid", // seller dono da promoção; null para promoções da loja
            "items": ["SkuId-uuid"], // SKUs afetados; vazio para promoções no nível do pedido
            "coupon": { "_id": "CouponId-uuid", "type": "default", "code": "10OFF" } // presente quando exige cupom
        }
    ],
    "points": [], // pontos de fidelidade aplicados, quando houver
    "donations": [], // doações vinculadas ao pedido, quando houver
    "orderSource": {}, // origem do pedido (device/utm)
    "summary": {
        "items": 2, // quantidade de itens do pedido
        "total": 399.8, // soma dos preços de cada item * quantidade
        "totalPriceDiscount": 10, // soma dos descontos dos itens
        "totalShippingCost": 18.85, // soma dos custos de frete
        "totalShippingDiscount": 0, // soma dos descontos de frete
        "ordersDiscount": 0, // desconto aplicado ao pedido inteiro
        "maxShippingTime": 4, // maior prazo de entrega entre os itens
        "deliveryTimeType": "DAYS", // unidade do prazo: DAYS | MINUTES
        "taxes": 0, // impostos
        "finalPrice": 408.65, // preço final (total - descontos + frete + impostos)
        "donationAmount": 0, // total de doações
        "points": { "currencyAmount": 0, "amount": 0 } // pontos/cashback do pedido
    },
    "customer": { // dados do cliente (fictícios; sem PII real)
        "name": "Cliente Teste",
        "type": "individual",
        "document": "00000000000",
        "email": "cliente@example.com",
        "ref": "customer-ref-0001",
        "phone": { "countryCode": "55", "areaCode": "11", "number": "999999999" },
        "metadata": {}
    },
    "deliveryAddress": { // endereço de entrega (fictício)
        "receiverName": "Cliente Teste",
        "street": "Rua Exemplo",
        "number": "100",
        "complement": "Apto 1",
        "neighborhood": "Bairro Exemplo",
        "city": "São Paulo",
        "shortState": "SP",
        "state": "São Paulo",
        "zipcode": "00000-000",
        "countryCode": "BR"
    },
    "items": [ // itens do pedido (um por SKU); aqui há dois sellers distintos
        {
            "isVirtual": false, // produto virtual/digital?
            "skuId": "SkuId-uuid",
            "sellerSkuId": "SellerRef-uuid", // referência do SKU no seller
            "offerId": "OfferId-uuid",
            "name": "Produto de Teste Preto Único",
            "productName": "Produto de Teste",
