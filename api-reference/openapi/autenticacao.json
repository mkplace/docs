  "paths": {
    "/token": {
      "post": {
        "summary": "Gerar token",
        "description": "### Gerando Token \n\nUtilizamos como padrão de token de acesso, o padrão `OAuth2`, sendo assim, após o cadastro do vendedor dentro da aplicação e com as chaves em mãos, devolvemos um token de acesso em formato JWT que deverá estar em todos os cabeçalhos de todas as requisições que forem feitas para os nossos serviços.\n\n* [O quê é um token JWT?](https://www.devmedia.com.br/como-o-jwt-funciona/40265)\n* [O quê é o padrão OAuth 2.0](https://www.treinaweb.com.br/blog/o-que-e-oauth-2#:~:text=OAuth%202%20%C3%A9%20um%20protocolo,n%C3%A3o%20o%20acesso%20%C3%A0%20aplica%C3%A7%C3%A3o.)\n\nPara exemplificar melhor, segue um fluxo abaixo:\n\n```mermaid\nsequenceDiagram\n    Vendedor->>+Mkplace: Solicita token informando <br/> client_id e client_secret\n    Mkplace->>+Vendedor: Devolve Token com prazo de expiração\n    Vendedor->>+Mkplace: Requisita uma ação de um dado protegido\n    Mkplace->>+Vendedor: Retorna dado protegido\n```",
        "operationId": "post-token",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "client_id": {
                    "type": "string"
                  },
                  "client_secret": {
                    "type": "string"
                  },
                  "grant_type": {
                    "type": "string",
                    "default": "client_credentials"
                  }
                },
                "required": [
                  "client_id",
                  "client_secret",
                  "grant_type"
                ]
              },
              "examples": {
                "Example 1": {
                  "value": {
                    "client_id": "Client_id",
                    "client_secret": "client_secret",
                    "grant_type": "client_credentials"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string"
                    },
                    "expires_in": {
                      "type": "integer"
                    },
                    "refresh_expires_in": {
                      "type": "integer"
                    },
                    "token_type": {
                      "type": "string"
                    },
                    "not-before-policy": {
                      "type": "integer"
                    },
                    "scope": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "access_token",
                    "expires_in",
                    "refresh_expires_in",
                    "token_type",
                    "not-before-policy",
                    "scope"
                  ],
                  "x-examples": {
                    "Example 1": {
                      "access_token": "eyJhbGciOiJSUzI1NiIsInR5cCIgOiAiSldUIiwia2lkIiA6ICJLeWJISHMyQzY0YWQzLVJJVmVLTXQ5ZE9EUzkxTUxzTWJ6bi1wYm5TQS1BIn0..PSVJ4yxYvzPiDfq9Kqmnp4NnN9vtnXzVi6v5wr1igmRmn0WtGYblCat7Qlitncc0Lfblcv3Cx6i41JdXFUQjDxIDtCc4u7paq4bhSpfqDmsSPrtb-fTiKTrY3UoUl5s-OWZW6Sz32erlJwjit-YNfbQnG0sYhYoGp3EN5pMc9LyKHq2N_kXxeNv8A3yQuzNCAK1fs6pTQi6nNHQzVdpgh8RaP-PGd-DsPoRYCGjYGTNpwA_8jjEdfD7f0WpheTTbKFXwFeJgStmNVhEnIJvd6XPngM_2etW0dg3yIfr6-WAV3nXTqjYwlSGxccE0LU6wexSWxyQ0iedV_KqTUyW_zQ",
                      "expires_in": 300,
                      "refresh_expires_in": 0,
                      "token_type": "Bearer",
                      "not-before-policy": 1662651813,
                      "scope": "profile email"
                    }
                  }
                },
                "examples": {
                  "Resposta OK": {
                    "value": {
                      "access_token": "eyJhbGciOiJSUzI1NiIsInR5cC...",
                      "expires_in": 300,
                      "refresh_expires_in": 0,
                      "token_type": "Bearer",
                      "not-before-policy": 1662651813,
                      "scope": "profile email"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "error_description": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error",
                    "error_description"
                  ],
                  "x-examples": {
                    "Example 1": {
                      "error": "invalid_client",
                      "error_description": "Invalid client credentials"
                    }
                  }
                },
                "examples": {
                  "Client id inválido": {
                    "value": {
                      "error": "invalid_client",
                      "error_description": "Invalid client credentials"
                    }
                  },
                  "Grant type inválido": {
                    "value": {
                      "error": "unsupported_grant_type",
                      "error_description": "Unsupported grant_type"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    },
                    "error_description": {
                      "type": "string"
                    }
                  },
                  "x-examples": {
                    "Example 1": {
                      "error": "unauthorized_client",
                      "error_description": "Invalid client secret"
                    }
                  }
                },
                "examples": {
                  "Client secret não autorizado": {
                    "value": {
                      "error": "unauthorized_client",
                      "error_description": "Invalid client secret"
                    }
                  }
                }
              }
            }
          }
        },
