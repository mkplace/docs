{
  "openapi": "3.0.3",
  "info": {
    "title": "Webhooks de Pedidos",
    "version": "1.0.0",
    "description": "Gerenciamento de webhooks de pedidos e referencia do payload do recurso Order (pedido) enviado nas notificacoes."
  },
  "servers": [
    {
      "url": "https://api.main.mkplace.com",
      "description": "API Mkplace (gerenciamento de webhooks)"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Webhooks de pedidos",
      "description": "Operacoes para gerenciar webhooks de pedidos do seller."
    }
  ],
  "paths": {
    "/webhook": {
      "get": {
        "summary": "Listar webhooks",
        "operationId": "listWebhooks",
        "x-mint": { "href": "/api-reference/lojas-webhooks-pedidos/listar-webhooks" },
        "tags": ["Webhooks de pedidos"],
        "security": [{ "bearerAuth": [] }],
        "description": "## Descricao\n\nLista todos os webhooks do seller solicitante.\n\n### Regras\n\n- Autorizacao e obrigatoria;\n- O escopo `sales/webhook/read` e obrigatorio;\n- O contexto de seller e store e obrigatorio.",
        "parameters": [
          {
            "schema": { "type": "string" },
            "in": "query",
            "name": "endpoint",
            "description": "Endpoint do webhook"
          },
          {
            "schema": { "type": "string" },
            "in": "query",
            "name": "statusFilter",
            "description": "Filtro de status associado ao webhook. E possivel enviar multiplos valores de statusFilter."
          },
          {
            "schema": { "type": "string", "enum": ["keycloak", "no-auth"] },
            "in": "query",
            "name": "authType",
            "description": "Filtra os webhooks pelo tipo de autenticacao."
          },
          {
            "schema": { "type": "string" },
            "in": "query",
            "name": "sellerId",
            "description": "Filtra os webhooks pelo ID do seller. Usado quando o seller nao esta no contexto do token."
          },
          {
            "schema": { "type": "string", "default": "1" },
            "in": "query",
            "name": "page",
            "description": "Pagina que sera listada"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "description": "Lista paginada de webhooks.",
                  "type": "object",
                  "properties": {
                    "docs": {
                      "type": "array",
                      "uniqueItems": true,
                      "items": { "$ref": "#/components/schemas/Webhook" }
                    },
                    "total": { "type": "number" },
                    "limit": { "type": "number" },
                    "page": { "type": "string" },
                    "pages": { "type": "number" }
                  }
                },
                "examples": {
                  "WebhookListResponse": {
                    "value": {
                      "docs": [
                        {
                          "_id": "webhookId",
                          "storeId": "string",
                          "sellerId": "string",
                          "endpoint": "https://seller-endpoint.example.com/notification/test",
                          "statusFilter": ["BILLED"],
                          "requestConfiguration": {
                            "headers": {
                              "Content-Type": "application/json",
                              "Authorization": "Bearer <TOKEN>"
                            }
                          },
                          "createdAt": "2022-01-01T14:39:25.835Z",
                          "updatedAt": "2022-01-01T17:23:59.897Z",
                          "__v": 0
                        }
                      ],
                      "total": 1,
                      "limit": 50,
                      "page": "1",
                      "pages": 1
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "examples": {
                  "Request Authorization without permission": {
                    "value": {
                      "exceptionType": "ForbiddenError",
                      "message": "You have not permission for this operation (sales/webhook/read)"
                    }
                  },
                  "Request Authorization without context": {
                    "value": {
                      "exceptionType": "ForbiddenError",
                      "message": "Contexts storeId, sellerId are required for this operation"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Criar webhook",
        "operationId": "createWebhook",
        "x-mint": { "href": "/api-reference/lojas-webhooks-pedidos/criar-webhook" },
        "tags": ["Webhooks de pedidos"],
        "security": [{ "bearerAuth": [] }],
        "description": "## Descricao\n\nCria um webhook para o seller solicitante.\n\n### Regras\n\n- Autorizacao e obrigatoria;\n- O escopo `sales/webhook/create` e obrigatorio;\n- O contexto de seller e store e obrigatorio.",
        "requestBody": {
          "description": "Dados do webhook a ser criado.",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WebhookInput" },
              "examples": {
                "Example 1": {
                  "value": {
                    "endpoint": "https://seller-endpoint.example.com/notification",
                    "statusFilter": ["PRE-ORDER"],
                    "requestConfiguration": {
                      "headers": {
                        "Authorization": "Bearer <TOKEN>",
                        "Content-Type": "application/json"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Webhook" },
                "examples": {
                  "example-1": {
                    "value": {
                      "statusFilter": ["SENT", "CANCELED"],
                      "requestConfiguration": {
                        "headers": { "Content-Type": "application/json" }
                      },
                      "endpoint": "https://seller-endpoint.example.com/notification",
                      "storeId": "9qAcdOluBG",
                      "sellerId": "0RCMBSNbOl",
                      "_id": "uKP9_BKkDf",
                      "createdAt": "2022-04-18T17:58:12.023Z",
                      "updatedAt": "2022-04-18T17:58:12.023Z",
                      "__v": 0
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "examples": {
                  "When endpoint was not provided": {
                    "value": {
                      "exceptionType": "ValidationError",
                      "message": "There are validations errors, error 'must have required property 'endpoint''"
                    }
                  },
                  "When statusFilter was not provided": {
                    "value": {
                      "exceptionType": "ValidationError",
                      "message": "There are validations errors, error 'must have required property 'statusFilter''"
                    }
                  },
                  "When statusFilter array is empty": {
                    "value": {
                      "exceptionType": "ValidationError",
                      "message": "There are validations errors, field '/statusFilter' error 'must NOT have fewer than 1 items'"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "examples": {
                  "Request does not have context permission": {
                    "value": {
                      "exceptionType": "ForbiddenError",
                      "message": "You have not permission for this operation (sales/webhook/create)"
                    }
                  },
                  "Request without storeId or sellerId profile": {
                    "value": {
                      "exceptionType": "ForbiddenError",
                      "message": "Contexts storeId, sellerId are required for this operation"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/webhook/id/{webhookId}": {
      "parameters": [
        {
          "schema": { "type": "string" },
          "name": "webhookId",
          "in": "path",
          "required": true,
          "description": "ID do webhook que sera consultado"
        }
      ],
      "get": {
        "summary": "Buscar webhook por ID",
        "operationId": "getWebhookById",
        "x-mint": { "href": "/api-reference/lojas-webhooks-pedidos/buscar-webhook-por-id" },
        "tags": ["Webhooks de pedidos"],
        "security": [{ "bearerAuth": [] }],
        "description": "## Descricao\n\nBusca um webhook pelo seu ID.\n\n### Regras\n\n- Autorizacao e obrigatoria;\n- O escopo `sales/webhook/read` e obrigatorio;\n- O contexto de seller e store e obrigatorio.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Webhook" },
                "examples": {
                  "Webhook Response": {
                    "value": {
                      "statusFilter": ["BILLED"],
                      "requestConfiguration": {
                        "headers": {
                          "Content-Type": "application/json",
                          "Authorization": "Bearer <TOKEN>"
                        }
                      },
                      "_id": "webhookId",
                      "endpoint": "https://seller-endpoint.example.com/notification/test",
                      "storeId": "string",
                      "sellerId": "string",
                      "createdAt": "2022-01-01T14:39:25.835Z",
                      "updatedAt": "2022-01-01T17:23:59.897Z",
                      "__v": 0
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "examples": {
                  "Request Authorization without permission": {
                    "value": {
                      "exceptionType": "ForbiddenError",
                      "message": "You have not permission for this operation (sales/webhook/read)"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "examples": {
                  "Webhook not found": {
                    "value": {
                      "exceptionType": "NotFoundError",
                      "message": "Webhook not found."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/webhook/{webhookId}": {
      "parameters": [
        {
          "schema": { "type": "string" },
          "name": "webhookId",
          "in": "path",
          "required": true,
          "description": "ID do webhook que sera atualizado ou removido"
        }
      ],
      "put": {
        "summary": "Atualizar webhook",
        "operationId": "updateWebhook",
        "x-mint": { "href": "/api-reference/lojas-webhooks-pedidos/atualizar-webhook" },
        "tags": ["Webhooks de pedidos"],
        "security": [{ "bearerAuth": [] }],
        "description": "## Descricao\n\nAtualiza o webhook com o ID informado.\n\n### Regras\n\n- Autorizacao e obrigatoria;\n- O escopo `sales/webhook/update` e obrigatorio;\n- O contexto de seller e store e obrigatorio.",
        "requestBody": {
          "description": "Novos dados do webhook.",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WebhookInput" },
              "examples": {
                "Ok": {
                  "value": {
                    "endpoint": "https://seller-endpoint.example.com/notification",
                    "statusFilter": ["PRE-ORDER"],
                    "requestConfiguration": {}
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Webhook" },
                "examples": {
                  "Ok": {
                    "value": {
                      "_id": "string",
                      "storeId": "string",
                      "sellerId": "string",
                      "endpoint": "https://seller-endpoint.example.com/notification",
                      "statusFilter": ["PRE-ORDER"],
                      "requestConfiguration": {},
                      "__v": 0,
                      "createdAt": "string",
                      "updatedAt": "string"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "examples": {
                  "When endpoint is not uri format": {
                    "value": {
                      "exceptionType": "ValidationError",
                      "message": "There are validations errors, field '/endpoint' error 'must match format \"uri\"'"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "examples": {
                  "Request does not have permission": {
                    "value": {
                      "exceptionType": "ForbiddenError",
                      "message": "You have not permission for this operation (sales/webhook/update)"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "examples": {
                  "Webhook not found": {
                    "value": {
                      "exceptionType": "NotFoundError",
                      "message": "Webhook not found."
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Remover webhook",
        "operationId": "deleteWebhook",
        "x-mint": { "href": "/api-reference/lojas-webhooks-pedidos/remover-webhook" },
        "tags": ["Webhooks de pedidos"],
        "security": [{ "bearerAuth": [] }],
        "description": "## Descricao\n\nRemove o webhook com o ID informado.\n\n### Regras\n\n- Autorizacao e obrigatoria;\n- O escopo `sales/webhook/delete` e obrigatorio;\n- O contexto de seller e store e obrigatorio.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "deleted": { "type": "boolean" } }
                },
                "examples": {
                  "Successful deletion": { "value": { "deleted": true } }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "examples": {
                  "Returns error if request doesn't provide a webhook Id": {
                    "value": {
                      "exceptionType": "ValidationError",
                      "message": "There are validations errors, error 'must have required property 'webhookId''"
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "examples": {
                  "Returns error if storeId is not provided": {
                    "value": {
                      "exceptionType": "ForbiddenError",
                      "message": "Contexts storeId, sellerId are required for this operation"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "examples": {
                  "Webhook ID was not found": {
                    "value": {
                      "exceptionType": "NotFoundError",
                      "message": "Webhook not found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token de acesso (Bearer) obrigatorio para todas as operacoes."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "description": "Estrutura padrao de erro retornada pela API.",
        "properties": {
          "exceptionType": { "type": "string", "description": "Tipo da excecao." },
          "message": { "type": "string", "description": "Mensagem descritiva do erro." }
        },
        "required": ["exceptionType", "message"]
      },
      "WebhookInput": {
        "type": "object",
        "description": "Dados de entrada para criacao ou atualizacao de um webhook de pedidos.",
        "required": ["endpoint", "statusFilter"],
        "properties": {
          "endpoint": {
            "type": "string",
            "format": "uri",
            "description": "URL do endpoint do seller que recebera as notificacoes de pedido."
          },
          "statusFilter": {
            "type": "array",
            "minItems": 1,
            "description": "Lista de status de pedido que disparam a notificacao no endpoint.",
            "items": {
              "type": "string",
              "enum": [
                "PRE-ORDER",
                "EXPIRED",
                "CANCELED",
                "WAITING-PAYMENT",
                "PAID",
                "BILLED",
                "SENT",
                "DELIVERED",
                "PARTIALLY-SENT",
                "PARTIALLY-DELIVERED",
                "PARTIALLY-BILLED",
                "IN-PROCESSING",
                "REFUNDED",
                "REPLACED",
                "RETURNED"
              ]
            }
          },
          "authType": {
            "type": "string",
            "nullable": true,
            "description": "Tipo de autenticacao usada nas requisicoes ao endpoint. Quando `keycloak`, o webhook obtem um token via client credentials antes de notificar.",
            "enum": ["keycloak", "no-auth"]
          },
          "authEndpoint": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "description": "URL do endpoint de autenticacao usado para obter o token. Obrigatorio quando `authType` for `keycloak`."
          },
          "credentials": {
            "type": "object",
            "nullable": true,
            "description": "Credenciais usadas para autenticar a requisicao. `clientId` e `clientSecret` sao obrigatorios quando `authType` for `keycloak`.",
            "properties": {
              "clientId": {
                "type": "string",
                "description": "Client ID usado na autenticacao Keycloak."
              },
              "clientSecret": {
                "type": "string",
                "description": "Client Secret usado na autenticacao Keycloak."
              }
            }
          },
          "channelSlug": {
            "type": "string",
            "nullable": true,
            "description": "Slug do canal ao qual o webhook esta associado."
          },
          "orderType": {
            "type": "string",
            "description": "Tipo de pedido filtrado pelo webhook.",
            "enum": ["ORDER", "LOYALTY", "SUBSCRIPTION"]
          },
          "requestConfiguration": {
            "type": "object",
            "nullable": true,
            "description": "Configuracoes adicionais da requisicao enviada ao endpoint, como cabecalhos HTTP.",
            "properties": {
              "headers": {
                "type": "object",
                "description": "Cabecalhos HTTP enviados na notificacao.",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        }
      },
      "Webhook": {
        "description": "Webhook de pedidos cadastrado para o seller.",
        "allOf": [
          {
            "type": "object",
            "properties": {
              "_id": { "type": "string", "description": "Identificador do webhook." },
              "storeId": { "type": "string", "description": "ID da store a qual o webhook pertence." },
              "accountId": { "type": "string", "description": "ID da conta (account) a qual o webhook pertence." },
              "sellerId": { "type": "string", "description": "ID do seller a qual o webhook pertence." },
              "accessToken": { "type": "string", "description": "Token de acesso obtido na autenticacao Keycloak, reutilizado ate expirar." },
              "expiresAt": { "type": "string", "format": "date-time", "description": "Data de expiracao do token de acesso." }
            },
            "required": ["_id", "storeId"]
          },
          { "$ref": "#/components/schemas/WebhookInput" },
          {
            "type": "object",
            "properties": {
              "createdAt": { "type": "string", "description": "Data de criacao." },
              "updatedAt": { "type": "string", "description": "Data da ultima atualizacao." },
              "__v": { "type": "number", "description": "Chave de versao do banco de dados." }
            },
            "required": ["createdAt", "updatedAt"]
          }
        ]
      },
      "Order": {
        "type": "object",
        "description": "Pedido. Corresponde ao payload enviado nas notificacoes de webhook de pedidos.",
        "required": ["_id", "clientId", "storeId", "status", "items"],
        "properties": {
          "_id": { "type": "string" },
          "clientId": { "type": "string" },
          "storeId": { "type": "string" },
          "accountId": { "type": "string" },
          "customer": { "$ref": "#/components/schemas/Customer" },
          "orderRef": { "type": "string", "description": "Referência interna do pedido." },
          "isOrderModified": { "type": "boolean" },
          "paymentStatus": {
            "type": "string",
            "enum": [
              "CANCELED",
              "CREATED",
              "ERROR",
              "EXPIRED",
              "PAID",
              "PARTIAL-PAID",
              "PRE-APPROVED",
              "PRE-ORDER",
              "REFUNDED",
              "WAITING-PAYMENT"
            ]
          },
          "payments": {
            "type": "array",
            "items": { "type": "object" }
          },
          "status": {
            "type": "string",
            "enum": [
              "PRE-ORDER",
              "WAITING-PAYMENT",
              "IN-PROCESSING",
              "EXPIRED",
              "PARTIAL-PAID",
              "PAID",
              "PARTIALLY-BILLED",
              "BILLED",
              "PARTIALLY-SENT",
              "SENT",
              "PARTIALLY-DELIVERED",
              "DELIVERED",
              "REFUNDED",
              "REPLACED",
              "RETURNED",
              "CANCELED"
            ]
          },
          "substatus": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "reason": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "summary": {
            "type": "object",
            "properties": {
              "_id": { "type": "string" },
              "items": { "type": "integer" },
              "total": { "type": "number" },
              "finalPrice": { "type": "number" },
              "totalPriceDiscount": { "type": "integer" },
              "totalShippingCost": { "type": "integer" },
              "totalShippingDiscount": { "type": "integer" },
              "maxShippingTime": { "type": "integer" },
              "deliveryTimeType": { "type": "string" },
              "ordersDiscount": { "type": "integer" },
              "taxes": { "type": "integer" },
              "donationAmount": { "type": "integer" },
              "points": {
                "type": "object",
                "properties": {
                  "currencyAmount": { "type": "integer" },
                  "amount": { "type": "integer" }
                }
              }
            }
          },
          "deliveryAddress": {
            "type": "object",
            "properties": {
              "_id": { "type": "string" },
              "receiverName": { "type": "string" },
              "street": { "type": "string" },
              "city": { "type": "string" },
              "complement": { "type": "string" },
              "shortState": { "type": "string" },
              "state": { "type": "string" },
              "number": { "type": "string" },
              "zipcode": { "type": "string" },
              "countryCode": { "type": "string" },
              "neighborhood": { "type": "string" },
              "metadata": {
                "type": "object",
                "properties": { "type": { "type": "string" } }
              }
            }
          },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Items" }
          },
          "shipments": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Shipments" }
          },
          "transactionId": { "type": "string" },
          "verifyToken": { "type": "string" },
          "exceptionDetails": { "type": "string", "nullable": true },
          "metadata": { "type": "object" },
          "orderSource": { "type": "object" },
          "parentOrderId": { "type": "string" },
          "promotions": {
            "type": "array",
            "items": { "type": "object" }
          },
          "cartId": { "type": "string" },
          "channelSlug": { "type": "string" },
          "stockReservation": { "type": "boolean" },
          "type": {
            "type": "string",
